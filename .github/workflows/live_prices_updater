name: TradingView to Sheets Automator

on:
  workflow_dispatch: # Allows manual trigger and cron-job.org API trigger

jobs:
  run-updater:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Set up Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18'

      - name: Install Node dependencies
        run: npm install @mathieuc/tradingview

      - name: Run JS Bot
        run: node bot.js

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: Install Python dependencies
        run: pip install google-api-python-client google-auth-httplib2 google-auth-oauthlib gspread

      - name: Run Python Sheet Updater
        env:
          GCP_CREDENTIALS: ${{ secrets.GCP_CREDENTIALS }}
        run: python live_prices.py
